# --- Railway Postgres (private vs public URL) ---
# DATABASE_URL — often the internal host (*.railway.internal); only works inside Railway’s network.
# DATABASE_PUBLIC_URL — proxied URL (*.proxy.rlwy.net) for laptop, Vercel, etc.
# Runtime + Prisma CLI (`npm run db:*`) resolve via src/lib/resolve-database-url.ts (see prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.railway.internal:5432/railway"
DATABASE_PUBLIC_URL="postgresql://USER:PASSWORD@HOST.proxy.rlwy.net:5432/railway"

# --- Admin (server-only; never NEXT_PUBLIC_) ---
ADMIN_PASSWORD="change-me-long-random"
# Optional: separate secret for JWT signing; defaults to ADMIN_PASSWORD if unset.
# ADMIN_SESSION_SECRET="another-long-random-string"

# --- Bassik (events / offers on home page) ---
BASSIK_BASE_URL="https://your-bassik-domain.com"
# Optional: max wait for Bassik (ms). Prevents the offers block from hanging the whole page.
# BASSIK_FETCH_TIMEOUT_MS=4000

# Optional public fallbacks if DB row missing
# NEXT_PUBLIC_HERO_VIDEO_URL=
# NEXT_PUBLIC_HERO_POSTER_URL=
# NEXT_PUBLIC_BOOK_TABLE_URL="#book"
# NEXT_PUBLIC_PHONE=
# NEXT_PUBLIC_WHATSAPP=
# NEXT_PUBLIC_INSTAGRAM=
# NEXT_PUBLIC_MAPS_URL=

# Vercel Blob — required for /admin/hero file uploads (auto-set when you connect Blob on Vercel)
# BLOB_READ_WRITE_TOKEN=

# Hero carousel: add HeroSlide rows in /admin/hero or run `npm run db:seed`
